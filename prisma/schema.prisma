// Banya-Digital ERP — core PostgreSQL schema (T-002)
// Grouped by domain module; extend via new models, not wide JSON blobs.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (staff / operator sessions, T-009) ─────────────────────────────────

/// Роли персонала ERP (не гостевые сессии).
enum StaffRole {
  owner
  ops
  admin
  warehouse
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String?
  role          StaffRole @default(ops)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]

  @@map("users")
}

model Account {
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@id([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@id([identifier, token])
  @@map("verification_tokens")
}

// ─── Shared / core ───────────────────────────────────────────────────────────

/// Тип зоны комплекса (T-020): баня, urban SPA, white-label справочник.
enum HallZoneType {
  STEAM_ROOM
  VIP_SUITE
  HAMMAM
  HAY_LOFT
  THERMAL
  POOL
}

/// Зал или зона комплекса (yield, unit economics scope).
model Hall {
  id        String        @id @default(cuid())
  code      String        @unique
  name      String
  zoneType  HallZoneType  @default(STEAM_ROOM)
  /// Доп. метки white-label (например «ritual», «corporate»).
  tags      String[]      @default([])
  capacity  Int?
  isActive  Boolean       @default(true)
  createdAt DateTime      @default(now())
  updatedAt DateTime      @updatedAt

  services      Service[]
  bookings      Booking[]
  programTimings ProgramTiming[]
  shiftChecklists ShiftChecklist[]
  revenueLines  RevenueLine[]
  costLines     CostLine[]
  retailSales   RetailSale[]

  @@map("halls")
}

/// Услуга или товар (спа-программа, доп. продукт).
model Service {
  id          String      @id @default(cuid())
  hallId      String?
  hall        Hall?       @relation(fields: [hallId], references: [id], onDelete: SetNull)
  code        String      @unique
  name        String
  kind        ServiceKind @default(SERVICE)
  basePrice   Decimal?    @db.Decimal(12, 2)
  isActive    Boolean     @default(true)
  createdAt   DateTime    @default(now())
  updatedAt   DateTime    @updatedAt

  bookings     Booking[]
  revenueLines RevenueLine[]
  costLines    CostLine[]

  @@index([hallId])
  @@map("services")
}

enum ServiceKind {
  SERVICE
  PRODUCT
}

// ─── CRM ─────────────────────────────────────────────────────────────────────

model Guest {
  id        String   @id @default(cuid())
  fullName  String
  phone     String?
  email     String?
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  bookings Booking[]

  @@index([phone])
  @@map("guests")
}

model Booking {
  id           String        @id @default(cuid())
  guestId      String
  guest        Guest         @relation(fields: [guestId], references: [id], onDelete: Restrict)
  hallId       String?
  hall         Hall?         @relation(fields: [hallId], references: [id], onDelete: SetNull)
  serviceId    String?
  service      Service?      @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  spaProgramId String?
  spaProgram   SpaProgram?   @relation(fields: [spaProgramId], references: [id], onDelete: SetNull)
  status       BookingStatus @default(PENDING)
  startsAt     DateTime
  endsAt       DateTime
  partySize    Int           @default(1)
  notes        String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  programTimings ProgramTiming[]
  revenueLines   RevenueLine[]

  @@index([guestId])
  @@index([hallId, startsAt])
  @@index([status])
  @@map("bookings")
}

enum BookingStatus {
  PENDING
  CONFIRMED
  CHECKED_IN
  COMPLETED
  CANCELLED
  NO_SHOW
}

/// Шаблон spa-программы (контур CRM + operations timings).
model SpaProgram {
  id              String   @id @default(cuid())
  code            String   @unique
  name            String
  description     String?
  durationMinutes Int
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  bookings       Booking[]
  programTimings ProgramTiming[]

  @@map("spa_programs")
}

// ─── Operations: timings & kitchen sync ──────────────────────────────────────

/// Слот программы в зале (мастер / зона).
model ProgramTiming {
  id           String   @id @default(cuid())
  spaProgramId String
  spaProgram   SpaProgram @relation(fields: [spaProgramId], references: [id], onDelete: Cascade)
  bookingId    String?
  booking      Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  hallId       String
  hall         Hall     @relation(fields: [hallId], references: [id], onDelete: Restrict)
  startsAt     DateTime
  endsAt       DateTime
  staffLabel   String?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  kitchenSlots KitchenSlot[]

  @@index([hallId, startsAt])
  @@index([bookingId])
  @@map("program_timings")
}

/// Синхронизация с кухней (слот подачи / prep).
model KitchenSlot {
  id              String            @id @default(cuid())
  programTimingId String
  programTiming   ProgramTiming     @relation(fields: [programTimingId], references: [id], onDelete: Cascade)
  startsAt        DateTime
  endsAt          DateTime
  station         String?
  syncStatus      KitchenSyncStatus @default(PLANNED)
  notes           String?
  /// T-018: кто и когда закрыл конфликт (demo: demo-user).
  resolvedAt      DateTime?
  resolvedBy      String?
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt

  @@index([programTimingId])
  @@index([startsAt])
  @@index([syncStatus, resolvedAt])
  @@map("kitchen_slots")
}

enum KitchenSyncStatus {
  PLANNED
  CONFIRMED
  IN_PROGRESS
  DONE
  CONFLICT
}

// ─── Operations: shift checklists ────────────────────────────────────────────

model ShiftChecklist {
  id        String   @id @default(cuid())
  hallId    String?
  hall      Hall?    @relation(fields: [hallId], references: [id], onDelete: SetNull)
  shiftDate DateTime @db.Date
  shiftType ShiftType @default(DAY)
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  items ChecklistItem[]

  @@index([shiftDate])
  @@index([hallId])
  @@map("shift_checklists")
}

enum ShiftType {
  DAY
  EVENING
  NIGHT
}

model ChecklistItem {
  id          String    @id @default(cuid())
  checklistId String
  checklist   ShiftChecklist @relation(fields: [checklistId], references: [id], onDelete: Cascade)
  sortOrder   Int       @default(0)
  label       String
  completedAt DateTime?
  completedBy String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@index([checklistId])
  @@map("checklist_items")
}

// ─── Operations: inventory (FIFO organic) ────────────────────────────────────

model InventoryItem {
  id           String       @id @default(cuid())
  sku          String       @unique
  name         String
  organicType  OrganicSku   @default(HAY)
  unit         String       @default("kg")
  reorderLevel Decimal?     @db.Decimal(12, 3)
  isActive     Boolean      @default(true)
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  lots InventoryLot[]

  @@map("inventory_items")
}

enum OrganicSku {
  HAY
  FIR
}

/// Партия для FIFO: остаток уменьшается движениями OUT.
model InventoryLot {
  id            String   @id @default(cuid())
  itemId        String
  item          InventoryItem @relation(fields: [itemId], references: [id], onDelete: Restrict)
  lotCode       String
  receivedAt    DateTime
  quantityIn    Decimal  @db.Decimal(12, 3)
  quantityLeft  Decimal  @db.Decimal(12, 3)
  unitCost      Decimal? @db.Decimal(12, 4)
  expiresAt     DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  movements StockMovement[]
  costLines CostLine[]

  @@unique([itemId, lotCode])
  @@index([itemId, receivedAt])
  @@map("inventory_lots")
}

model StockMovement {
  id          String            @id @default(cuid())
  lotId       String
  lot         InventoryLot      @relation(fields: [lotId], references: [id], onDelete: Restrict)
  type        StockMovementType
  quantity    Decimal           @db.Decimal(12, 3)
  reference   String?
  notes       String?
  occurredAt  DateTime          @default(now())
  createdAt   DateTime          @default(now())

  @@index([lotId, occurredAt])
  @@map("stock_movements")
}

enum StockMovementType {
  IN
  OUT
  ADJUST
}

// ─── Finance: unit economics lines ───────────────────────────────────────────

/// Выручка по залу / услуге / дню (агрегация в dashboard позже).
model RevenueLine {
  id           String   @id @default(cuid())
  hallId       String?
  hall         Hall?    @relation(fields: [hallId], references: [id], onDelete: SetNull)
  serviceId    String?
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  bookingId    String?
  booking      Booking? @relation(fields: [bookingId], references: [id], onDelete: SetNull)
  amount       Decimal  @db.Decimal(12, 2)
  currency     String   @default("RUB")
  businessDate DateTime @db.Date
  description  String?
  createdAt    DateTime @default(now())

  @@index([businessDate])
  @@index([hallId, businessDate])
  @@map("revenue_lines")
}

/// COGS и прочие затраты (привязка к лоту для органики).
model CostLine {
  id           String   @id @default(cuid())
  hallId       String?
  hall         Hall?    @relation(fields: [hallId], references: [id], onDelete: SetNull)
  serviceId    String?
  service      Service? @relation(fields: [serviceId], references: [id], onDelete: SetNull)
  lotId        String?
  lot          InventoryLot? @relation(fields: [lotId], references: [id], onDelete: SetNull)
  amount       Decimal  @db.Decimal(12, 2)
  costType     CostType @default(COGS)
  currency     String   @default("RUB")
  businessDate DateTime @db.Date
  description  String?
  createdAt    DateTime @default(now())

  @@index([businessDate])
  @@index([hallId, businessDate])
  @@map("cost_lines")
}

enum CostType {
  COGS
  LABOR
  OVERHEAD
  OTHER
}

/// План выручки на календарную неделю (пн–вс, Europe/Moscow) — T-019.
model RevenueWeekPlan {
  id        String   @id @default(cuid())
  weekStart DateTime @db.Date
  amount    Decimal  @db.Decimal(12, 2)
  currency  String   @default("RUB")
  notes     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([weekStart])
  @@map("revenue_week_plans")
}

// ─── Retail: bar / shop sales (T-021) ────────────────────────────────────────

/// Розничный продукт (бар/магазин при бане): цена и себестоимость на единицу.
model RetailProduct {
  id          String   @id @default(cuid())
  name        String
  category    String
  unit        String   @default("шт")
  price       Decimal  @db.Decimal(12, 2)
  cogsPerUnit Decimal  @db.Decimal(12, 2)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  sales RetailSale[]

  @@index([category])
  @@map("retail_products")
}

/// Продажа розничного продукта (кол-во, время продажи, опционально зона/зал).
model RetailSale {
  id        String        @id @default(cuid())
  productId String
  product   RetailProduct @relation(fields: [productId], references: [id], onDelete: Restrict)
  quantity  Decimal       @db.Decimal(12, 3)
  soldAt    DateTime
  hallId    String?
  hall      Hall?         @relation(fields: [hallId], references: [id], onDelete: SetNull)
  createdAt DateTime      @default(now())

  @@index([soldAt])
  @@index([productId, soldAt])
  @@map("retail_sales")
}
