# PostgreSQL — local Docker (see docker-compose.yml) or Neon/Supabase
DATABASE_URL="postgresql://banya:banya@localhost:5432/banya_digital?schema=public"

# Production app URL (Vercel) — set after first deploy, e.g. https://your-app.vercel.app
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# Auth.js (NextAuth v5) — staff sessions (T-009)
# Generate: openssl rand -base64 32
AUTH_SECRET="replace-with-openssl-rand-base64-32"
AUTH_URL="http://localhost:3000"

# Demo staff password (seed only — set in .env, never commit real passwords)
DEMO_STAFF_PASSWORD="banya-demo"

# Pilot: skip Auth.js route protection (set false to re-enable login)
DEMO_SKIP_AUTH="true"

# Seed preset: banya (default) | urban-spa — white-label urban SPA demo (T-020)
# SEED_PRESET="banya"
